{
  "$schema": "https://raw.githubusercontent.com/nicerscheduler/tauri-apps/refs/heads/dev/crates/tauri-cli/schema.json",
  "productName": "Natives",
  "version": "0.1.0",
  "identifier": "ai.natives.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://127.0.0.1:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Natives",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "transparent": true,
        "decorations": false,
        "fullscreen": false,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: blob: http://asset.localhost; media-src 'self' asset: blob: http://asset.localhost; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; frame-src 'self' http://127.0.0.1:*",
      "assetProtocol": {
        "enable": true,
        "scope": ["**/*"]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "window-state": null,
    "single-instance": null,
    "updater": null,
    "log": null
  }
}
