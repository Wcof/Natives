    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^5.5.0",
    "adm-zip": "^0.5.17",
    "lucide-react": "^0.475.0",
    "marked": "^18.0.5",
    "monaco-editor": "^0.55.1",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
