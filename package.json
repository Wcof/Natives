{
  "name": "natives",
  "version": "0.1.0",
  "description": "AI Steam Base — 桌面应用容器",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development next dev -H 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "tsx --test src/**/*.test.ts",
    "electron:dev": "electron electron/main.ts",
